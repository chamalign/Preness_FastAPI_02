# Copy to `.env` and set values. See README.md 環境変数.
CONTENT_SOURCE_API_KEY=
ANALYSIS_API_KEY=
DATABASE_URL=postgresql://localhost:5432/preness_analysis
REDIS_URL=redis://localhost:6379/0
# GPT ナラティブ生成に必須. 未設定の場合 narratives はプレースホルダー文字列になる.
OPENAI_API_KEY=
